# ─── Domain ───
DOMAIN=envault.yourdomain.com

# ─── Database (use a strong password!) ───
DATABASE_USER=envault
DATABASE_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
DATABASE_NAME=envault

# ─── Vault ───
VAULT_TOKEN=CHANGE_ME_TO_A_RANDOM_TOKEN

# ─── Supabase Auth ───
# Get these from: https://supabase.com → Project Settings → API
JWKS_URL=https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json
JWT_ISSUER=https://YOUR_PROJECT_REF.supabase.co/auth/v1
JWT_AUDIENCE=

# ─── Supabase Frontend ───
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Server ───
LOG_LEVEL=info
RATE_LIMIT_AUTH=10
RATE_LIMIT_WRITE=30
RATE_LIMIT_READ=100
