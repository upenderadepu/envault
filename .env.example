# ─── Server ───
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
LOG_LEVEL=info

# ─── Database ───
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=envault
DATABASE_PASSWORD=envault_dev_password
DATABASE_NAME=envault
DATABASE_SSLMODE=disable

# ─── Vault ───
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token
VAULT_MOUNT_PREFIX=envault

# ─── Supabase Auth (required) ───
# Create a free project at https://supabase.com
# Find these values in: Project Settings > API
JWKS_URL=https://<your-project-ref>.supabase.co/auth/v1/.well-known/jwks.json
JWT_ISSUER=https://<your-project-ref>.supabase.co/auth/v1
JWT_AUDIENCE=

# ─── Supabase Frontend (required) ───
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── CORS ───
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Rate Limiting (requests per minute) ───
RATE_LIMIT_AUTH=10
RATE_LIMIT_WRITE=30
RATE_LIMIT_READ=100
