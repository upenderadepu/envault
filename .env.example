# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
LOG_LEVEL=debug

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=envault
DATABASE_PASSWORD=envault_dev_password
DATABASE_NAME=envault
DATABASE_SSLMODE=disable

# Vault
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=<root-token-from-init>
VAULT_MOUNT_PREFIX=envault

# Auth (Supabase JWKS)
JWKS_URL=https://<project>.supabase.co/auth/v1/.well-known/jwks.json
JWT_ISSUER=https://<project>.supabase.co/auth/v1
JWT_AUDIENCE=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Rate Limiting (requests per minute)
RATE_LIMIT_AUTH=10
RATE_LIMIT_WRITE=30
RATE_LIMIT_READ=100
